# Alinma Bank Ma3ak Environment Variables Template
# Copy this file to .env.local and fill in the values for local development.
# These environment variables must also be configured in Vercel.

# 1. Supabase Credentials (Optional - if USE_MOCK_DATA is false in src/lib/data/config.ts)
NEXT_PUBLIC_SUPABASE_URL=your-supabase-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key-bypass-rls

# 2. OpenAI GPT-4o-mini Integration (Optional - if USE_MOCK_AI is false in src/lib/data/config.ts)
OPENAI_API_KEY=your-openai-api-key-here
